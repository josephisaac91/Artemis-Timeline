# Environment / secrets
.env
.env.*
*.local
secrets.json
credentials.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor cruft
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
*.swp
*.swo
*~
.vscode/
.idea/

# Dependencies / build output
node_modules/
dist/
build/
.next/
.vercel/
.cache/

# Python scratchpads (if any)
__pycache__/
*.py[cod]
.venv/
venv/

# Raw photo originals at repo root — site uses optimized copies in web/ instead.
# Keep local copies on disk, but don't commit them (they're ~3 GB).
/*.jpg
/*.JPG
/*.jpeg
/*.JPEG
# (Allow the pngtree moon favicon explicitly — it IS served)
!pngtree-*.png
